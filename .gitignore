# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules
.pythonlibs

# Python
__pycache__/
*.pyc
.env

# uploaded/generated app files
storage/uploads/*
storage/exports/*
artifacts/bim-clash-detection/storage/uploads/*
artifacts/bim-clash-detection/storage/exports/*
!storage/uploads/.gitkeep
!storage/exports/.gitkeep
!artifacts/bim-clash-detection/storage/uploads/.gitkeep
!artifacts/bim-clash-detection/storage/exports/.gitkeep

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit
.cache/
.local/
